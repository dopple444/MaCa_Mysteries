generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOST
  PLAYER
  ADMIN
  SUPER_ADMIN
  CONTENT_EDITOR
  SUPPORT
  FINANCE
}

model User {
  id                            String                  @id @default(cuid())
  email                         String                  @unique
  name                          String
  role                          UserRole                @default(HOST)
  passwordHash                  String?
  emailVerifiedAt               DateTime?
  failedLoginCount              Int                     @default(0)
  lastFailedLoginAt             DateTime?
  lockedUntil                   DateTime?
  lastLoginAt                   DateTime?
  phoneNumber                   String                  @default("")
  phoneVerifiedAt               DateTime?
  notificationPrefs             Json                    @default("{}")
  sessions                      UserSession[]
  parties                       Party[]
  evidenceReveals               PartyEvidenceReveal[]
  finalRevealUnlocks            PartyFinalRevealState[]
  auditLogs                     AuditLog[]
  adminActionRequestsMade       AdminActionRequest[]    @relation("AdminActionRequestedBy")
  adminActionRequestsTargeting  AdminActionRequest[]    @relation("AdminActionTargetUser")
  adminActionRequestsReviewed   AdminActionRequest[]    @relation("AdminActionReviewedBy")
  accountRecoveryCasesRequested AccountRecoveryCase[]   @relation("AccountRecoveryRequestedBy")
  accountRecoveryCasesTargeting AccountRecoveryCase[]   @relation("AccountRecoveryTargetUser")
  accountRecoveryCasesReviewed  AccountRecoveryCase[]   @relation("AccountRecoveryReviewedBy")
  orders                        Order[]
  gameAccess                    UserGameAccess[]
  outboundMessages              OutboundMessage[]
  supportTickets                SupportTicket[]
  supportMessages               SupportTicketMessage[]
  completedResults              PartyResult[]
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
}

model UserSession {
  id              String    @id @default(cuid())
  tokenHash       String    @unique
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  ipAddress       String    @default("")
  userAgent       String    @default("")
  createdBy       String    @default("LOGIN")
  lastSeenAt      DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedByUserId String?
  revokeReason    String    @default("")
  createdAt       DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Party {
  id                          String                     @id @default(cuid())
  title                       String
  gameSlug                    String
  gameId                      String?
  game                        Game?                      @relation(fields: [gameId], references: [id])
  gameVersionId               String?
  gameVersion                 GameVersion?               @relation(fields: [gameVersionId], references: [id])
  hostId                      String
  host                        User                       @relation(fields: [hostId], references: [id])
  inviteCode                  String                     @unique
  status                      String                     @default("PENDING")
  hostSpoilerUnlockedAt       DateTime?
  hostSpoilerUnlockedByUserId String?
  guests                      Guest[]
  assignments                 PartyCharacterAssignment[]
  roundStates                 PartyRoundState[]
  evidenceReveals             PartyEvidenceReveal[]
  accusations                 PartyAccusation[]
  finalRevealState            PartyFinalRevealState?
  result                      PartyResult?
  auditLogs                   AuditLog[]
  toolInstances               PartyToolInstance[]
  unlockEvents                PartyUnlockEvent[]
  codeAttempts                PartyCodeAttempt[]
  assetViews                  PartyAssetView[]
  playerInteractions          PartyPlayerInteraction[]
  playerInventory             PartyPlayerInventory[]
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
}

model Guest {
  id                      String                     @id @default(cuid())
  partyId                 String
  party                   Party                      @relation(fields: [partyId], references: [id])
  name                    String                     @default("")
  email                   String
  status                  String                     @default("INVITED")
  invitationStatus        String                     @default("NOT_SENT")
  invitationLastQueuedAt  DateTime?
  invitationLastSentAt    DateTime?
  invitationResendCount   Int                        @default(0)
  invitationFailedAt      DateTime?
  invitationFailureDetail String                     @default("")
  guestToken              String                     @unique
  joinedAt                DateTime?
  assignments             PartyCharacterAssignment[]
  accusations             PartyAccusation[]
  toolInstances           PartyToolInstance[]
  unlockEventsAsActor     PartyUnlockEvent[]         @relation("UnlockActorGuest")
  unlockEventsAsTarget    PartyUnlockEvent[]         @relation("UnlockTargetGuest")
  codeAttempts            PartyCodeAttempt[]
  assetViews              PartyAssetView[]
  interactionsAsActor     PartyPlayerInteraction[]   @relation("InteractionActorGuest")
  interactionsAsTarget    PartyPlayerInteraction[]   @relation("InteractionTargetGuest")
  inventoryItems          PartyPlayerInventory[]
  createdAt               DateTime                   @default(now())

  @@index([partyId, invitationStatus])
}

model Game {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  tagline     String
  description String
  minPlayers  Int
  maxPlayers  Int
  durationMin Int
  durationMax Int
  status      String           @default("DRAFT")
  versions    GameVersion[]
  products    Product[]
  parties     Party[]
  userAccess  UserGameAccess[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model GameVersion {
  id                String                @id @default(cuid())
  gameId            String
  game              Game                  @relation(fields: [gameId], references: [id])
  versionNumber     Int
  status            String                @default("DRAFT")
  themes            Json                  @default("[]")
  contentWarnings   Json                  @default("[]")
  sourceKind        String                @default("MANUAL")
  sourceToolName    String                @default("")
  sourceToolVersion String                @default("")
  sourceNotes       String                @default("")
  publishedAt       DateTime?
  parties           Party[]
  characters        GameCharacter[]
  rounds            GameRound[]
  evidence          GameEvidence[]
  finalReveal       GameFinalReveal?
  mediaAssets       GameMediaAsset[]
  digitalArtifacts  GameDigitalArtifact[]
  characterTools    GameCharacterTool[]
  unlockRules       GameUnlockRule[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([gameId, versionNumber])
}

model GameCharacter {
  id                   String                     @id @default(cuid())
  gameVersionId        String
  gameVersion          GameVersion                @relation(fields: [gameVersionId], references: [id])
  key                  String
  name                 String
  publicBio            String
  privateBio           String                     @default("")
  isRequired           Boolean                    @default(true)
  sortOrder            Int                        @default(0)
  assignments          PartyCharacterAssignment[]
  cards                GameCard[]
  evidence             GameEvidence[]
  mediaAssets          GameMediaAsset[]
  digitalArtifacts     GameDigitalArtifact[]
  characterTools       GameCharacterTool[]
  unlockRules          GameUnlockRule[]           @relation("UnlockRuleRequiredCharacter")
  accusationsAsSuspect PartyAccusation[]          @relation("AccusedCharacter")
  victimInReveals      GameFinalReveal[]          @relation("VictimCharacter")
  killerInReveals      GameFinalReveal[]          @relation("KillerCharacter")
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@unique([gameVersionId, key])
}

model GameRound {
  id                       String                @id @default(cuid())
  gameVersionId            String
  gameVersion              GameVersion           @relation(fields: [gameVersionId], references: [id])
  key                      String
  title                    String
  summary                  String                @default("")
  sortOrder                Int                   @default(0)
  cards                    GameCard[]
  evidence                 GameEvidence[]
  mediaAssets              GameMediaAsset[]
  digitalArtifacts         GameDigitalArtifact[]
  unlockRulesRequiredRound GameUnlockRule[]      @relation("UnlockRuleRequiredRound")
  partyStates              PartyRoundState[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@unique([gameVersionId, key])
}

model GameCard {
  id                   String         @id @default(cuid())
  gameRoundId          String
  gameRound            GameRound      @relation(fields: [gameRoundId], references: [id])
  characterId          String?
  character            GameCharacter? @relation(fields: [characterId], references: [id])
  key                  String
  title                String
  body                 String
  visibility           String         @default("PLAYER_PRIVATE")
  requiredUnlockRuleId String         @default("")
  sortOrder            Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([gameRoundId, key])
  @@index([gameRoundId, visibility])
  @@index([requiredUnlockRuleId])
}

model GameEvidence {
  id                   String                @id @default(cuid())
  gameVersionId        String
  gameVersion          GameVersion           @relation(fields: [gameVersionId], references: [id])
  gameRoundId          String?
  gameRound            GameRound?            @relation(fields: [gameRoundId], references: [id])
  characterId          String?
  character            GameCharacter?        @relation(fields: [characterId], references: [id])
  key                  String
  title                String
  body                 String
  evidenceType         String                @default("TEXT")
  visibility           String                @default("PUBLIC")
  sortOrder            Int                   @default(0)
  partyReveals         PartyEvidenceReveal[]
  mediaAssets          GameMediaAsset[]
  digitalArtifacts     GameDigitalArtifact[]
  requiredUnlockRuleId String                @default("")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([gameVersionId, key])
  @@index([gameVersionId, visibility])
  @@index([gameRoundId])
  @@index([requiredUnlockRuleId])
}

model GameMediaAsset {
  id                   String                @id @default(cuid())
  gameVersionId        String
  gameVersion          GameVersion           @relation(fields: [gameVersionId], references: [id])
  gameRoundId          String?
  gameRound            GameRound?            @relation(fields: [gameRoundId], references: [id])
  characterId          String?
  character            GameCharacter?        @relation(fields: [characterId], references: [id])
  evidenceId           String?
  evidence             GameEvidence?         @relation(fields: [evidenceId], references: [id])
  key                  String
  title                String
  description          String                @default("")
  assetType            String                @default("DOCUMENT")
  url                  String
  mimeType             String                @default("")
  visibility           String                @default("PUBLIC")
  requiredUnlockRuleId String                @default("")
  digitalArtifacts     GameDigitalArtifact[]
  sortOrder            Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([gameVersionId, key])
  @@index([gameVersionId, visibility])
  @@index([gameRoundId])
  @@index([evidenceId])
  @@index([requiredUnlockRuleId])
}

model GameFinalReveal {
  id                String                  @id @default(cuid())
  gameVersionId     String                  @unique
  gameVersion       GameVersion             @relation(fields: [gameVersionId], references: [id])
  victimCharacterId String?
  victimCharacter   GameCharacter?          @relation("VictimCharacter", fields: [victimCharacterId], references: [id])
  killerCharacterId String?
  killerCharacter   GameCharacter?          @relation("KillerCharacter", fields: [killerCharacterId], references: [id])
  title             String
  victimRevealText  String                  @default("")
  killerRevealText  String                  @default("")
  solutionText      String                  @default("")
  epilogueText      String                  @default("")
  partyStates       PartyFinalRevealState[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([victimCharacterId])
  @@index([killerCharacterId])
}

model GameDigitalArtifact {
  id                   String          @id @default(cuid())
  gameVersionId        String
  gameVersion          GameVersion     @relation(fields: [gameVersionId], references: [id])
  gameRoundId          String?
  gameRound            GameRound?      @relation(fields: [gameRoundId], references: [id])
  characterId          String?
  character            GameCharacter?  @relation(fields: [characterId], references: [id])
  evidenceId           String?
  evidence             GameEvidence?   @relation(fields: [evidenceId], references: [id])
  mediaAssetId         String?
  mediaAsset           GameMediaAsset? @relation(fields: [mediaAssetId], references: [id])
  key                  String
  title                String
  description          String          @default("")
  artifactType         String          @default("DOCUMENT")
  visibility           String          @default("PLAYER_PRIVATE")
  requiredUnlockRuleId String          @default("")
  content              Json            @default("{}")
  sortOrder            Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([gameVersionId, key])
  @@index([gameVersionId, visibility])
  @@index([gameRoundId])
  @@index([characterId])
  @@index([requiredUnlockRuleId])
}

model GameCharacterTool {
  id            String              @id @default(cuid())
  gameVersionId String
  gameVersion   GameVersion         @relation(fields: [gameVersionId], references: [id])
  characterId   String
  character     GameCharacter       @relation(fields: [characterId], references: [id])
  key           String
  title         String
  description   String              @default("")
  toolType      String              @default("GENERIC")
  visibility    String              @default("PLAYER_PRIVATE")
  config        Json                @default("{}")
  sortOrder     Int                 @default(0)
  instances     PartyToolInstance[]
  unlockRules   GameUnlockRule[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([gameVersionId, key])
  @@index([characterId])
  @@index([gameVersionId, visibility])
}

model GameUnlockRule {
  id                  String              @id @default(cuid())
  gameVersionId       String
  gameVersion         GameVersion         @relation(fields: [gameVersionId], references: [id])
  requiredRoundId     String?
  requiredRound       GameRound?          @relation("UnlockRuleRequiredRound", fields: [requiredRoundId], references: [id])
  requiredCharacterId String?
  requiredCharacter   GameCharacter?      @relation("UnlockRuleRequiredCharacter", fields: [requiredCharacterId], references: [id])
  sourceToolId        String?
  sourceTool          GameCharacterTool?  @relation(fields: [sourceToolId], references: [id])
  key                 String
  title               String
  description         String              @default("")
  ruleType            String              @default("MANUAL")
  triggerType         String              @default("HOST_APPROVAL")
  targetType          String
  targetId            String
  unlockScope         String              @default("PLAYER")
  codeMode            String              @default("")
  config              Json                @default("{}")
  effect              Json                @default("{}")
  status              String              @default("DRAFT")
  sortOrder           Int                 @default(0)
  toolInstances       PartyToolInstance[]
  unlockEvents        PartyUnlockEvent[]
  codeAttempts        PartyCodeAttempt[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([gameVersionId, key])
  @@index([gameVersionId, status])
  @@index([targetType, targetId])
  @@index([sourceToolId])
}

model PartyRoundState {
  id          String    @id @default(cuid())
  partyId     String
  party       Party     @relation(fields: [partyId], references: [id])
  gameRoundId String
  gameRound   GameRound @relation(fields: [gameRoundId], references: [id])
  status      String    @default("LOCKED")
  unlockedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([partyId, gameRoundId])
}

model PartyEvidenceReveal {
  id               String       @id @default(cuid())
  partyId          String
  party            Party        @relation(fields: [partyId], references: [id])
  evidenceId       String
  evidence         GameEvidence @relation(fields: [evidenceId], references: [id])
  revealedByUserId String?
  revealedByUser   User?        @relation(fields: [revealedByUserId], references: [id])
  revealedAt       DateTime     @default(now())
  createdAt        DateTime     @default(now())

  @@unique([partyId, evidenceId])
  @@index([partyId, revealedAt])
}

model PartyFinalRevealState {
  id               String          @id @default(cuid())
  partyId          String          @unique
  party            Party           @relation(fields: [partyId], references: [id])
  finalRevealId    String
  finalReveal      GameFinalReveal @relation(fields: [finalRevealId], references: [id])
  victimRevealedAt DateTime?
  finalRevealedAt  DateTime?
  revealedByUserId String?
  revealedByUser   User?           @relation(fields: [revealedByUserId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PartyCharacterAssignment {
  id          String        @id @default(cuid())
  partyId     String
  party       Party         @relation(fields: [partyId], references: [id])
  guestId     String
  guest       Guest         @relation(fields: [guestId], references: [id])
  characterId String
  character   GameCharacter @relation(fields: [characterId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([partyId, guestId])
  @@unique([partyId, characterId])
}

model PartyAccusation {
  id                 String         @id @default(cuid())
  partyId            String
  party              Party          @relation(fields: [partyId], references: [id])
  guestId            String
  guest              Guest          @relation(fields: [guestId], references: [id])
  suspectCharacterId String?
  suspectCharacter   GameCharacter? @relation("AccusedCharacter", fields: [suspectCharacterId], references: [id])
  motiveNotes        String         @default("")
  evidenceNotes      String         @default("")
  accusationText     String         @default("")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([partyId, guestId])
  @@index([partyId, createdAt])
}

model PartyResult {
  id                String   @id @default(cuid())
  partyId           String   @unique
  party             Party    @relation(fields: [partyId], references: [id])
  completedByUserId String?
  completedByUser   User?    @relation(fields: [completedByUserId], references: [id])
  completedAt       DateTime @default(now())
  summary           Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([completedByUserId, completedAt])
}

model PartyToolInstance {
  id              String             @id @default(cuid())
  partyId         String
  party           Party              @relation(fields: [partyId], references: [id])
  characterToolId String
  characterTool   GameCharacterTool  @relation(fields: [characterToolId], references: [id])
  unlockRuleId    String?
  unlockRule      GameUnlockRule?    @relation(fields: [unlockRuleId], references: [id])
  guestId         String?
  guest           Guest?             @relation(fields: [guestId], references: [id])
  status          String             @default("ACTIVE")
  codeHash        String             @default("")
  codeSalt        String             @default("")
  usesRemaining   Int                @default(1)
  metadata        Json               @default("{}")
  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  codeAttempts    PartyCodeAttempt[]

  @@index([partyId, status])
  @@index([characterToolId])
  @@index([unlockRuleId])
  @@index([guestId])
}

model PartyUnlockEvent {
  id            String          @id @default(cuid())
  partyId       String
  party         Party           @relation(fields: [partyId], references: [id])
  unlockRuleId  String?
  unlockRule    GameUnlockRule? @relation(fields: [unlockRuleId], references: [id])
  actorGuestId  String?
  actorGuest    Guest?          @relation("UnlockActorGuest", fields: [actorGuestId], references: [id])
  targetGuestId String?
  targetGuest   Guest?          @relation("UnlockTargetGuest", fields: [targetGuestId], references: [id])
  targetType    String
  targetId      String
  unlockScope   String          @default("PLAYER")
  status        String          @default("UNLOCKED")
  metadata      Json            @default("{}")
  createdAt     DateTime        @default(now())

  @@index([partyId, createdAt])
  @@index([unlockRuleId])
  @@index([targetType, targetId])
  @@index([actorGuestId, createdAt])
  @@index([targetGuestId, createdAt])
}

model PartyCodeAttempt {
  id             String             @id @default(cuid())
  partyId        String
  party          Party              @relation(fields: [partyId], references: [id])
  unlockRuleId   String?
  unlockRule     GameUnlockRule?    @relation(fields: [unlockRuleId], references: [id])
  toolInstanceId String?
  toolInstance   PartyToolInstance? @relation(fields: [toolInstanceId], references: [id])
  actorGuestId   String?
  actorGuest     Guest?             @relation(fields: [actorGuestId], references: [id])
  codeHash       String             @default("")
  status         String
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now())

  @@index([partyId, createdAt])
  @@index([unlockRuleId])
  @@index([toolInstanceId])
  @@index([actorGuestId, createdAt])
}

model PartyAssetView {
  id         String   @id @default(cuid())
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id])
  guestId    String?
  guest      Guest?   @relation(fields: [guestId], references: [id])
  targetType String
  targetId   String
  metadata   Json     @default("{}")
  viewedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([partyId, viewedAt])
  @@index([guestId, viewedAt])
  @@index([targetType, targetId])
}

model PartyPlayerInteraction {
  id              String   @id @default(cuid())
  partyId         String
  party           Party    @relation(fields: [partyId], references: [id])
  actorGuestId    String?
  actorGuest      Guest?   @relation("InteractionActorGuest", fields: [actorGuestId], references: [id])
  targetGuestId   String?
  targetGuest     Guest?   @relation("InteractionTargetGuest", fields: [targetGuestId], references: [id])
  interactionType String
  sourceType      String   @default("")
  sourceId        String   @default("")
  status          String   @default("RECORDED")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([partyId, createdAt])
  @@index([actorGuestId, createdAt])
  @@index([targetGuestId, createdAt])
  @@index([interactionType, createdAt])
}

model PartyPlayerInventory {
  id         String   @id @default(cuid())
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id])
  guestId    String
  guest      Guest    @relation(fields: [guestId], references: [id])
  itemType   String
  itemId     String
  sourceType String   @default("")
  sourceId   String   @default("")
  status     String   @default("ACTIVE")
  metadata   Json     @default("{}")
  acquiredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([partyId, guestId, itemType, itemId])
  @@index([partyId, guestId])
  @@index([itemType, itemId])
}

model Product {
  id         String           @id @default(cuid())
  gameId     String
  game       Game             @relation(fields: [gameId], references: [id])
  orderItems OrderItem[]
  gameAccess UserGameAccess[]
  slug       String           @unique
  name       String
  priceCents Int
  currency   String           @default("USD")
  status     String           @default("DRAFT")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model Order {
  id               String                @id @default(cuid())
  userId           String?
  user             User?                 @relation(fields: [userId], references: [id])
  email            String
  status           String                @default("PENDING")
  paymentProvider  String                @default("")
  paymentReference String                @default("")
  subtotalCents    Int                   @default(0)
  totalCents       Int                   @default(0)
  currency         String                @default("USD")
  items            OrderItem[]
  webhookEvents    PaymentWebhookEvent[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Int      @default(1)
  unitPriceCents  Int
  totalPriceCents Int
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model UserGameAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  source    String   @default("ORDER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([status])
}

model OutboundMessage {
  id                String    @id @default(cuid())
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  partyId           String?
  channel           String
  recipient         String
  templateKey       String
  subject           String    @default("")
  bodyPreview       String    @default("")
  provider          String    @default("")
  providerMessageId String    @default("")
  status            String    @default("PENDING")
  errorMessage      String    @default("")
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([partyId, createdAt])
  @@index([channel, status])
}

model PaymentWebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  eventType   String
  status      String    @default("RECEIVED")
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id])
  payload     Json      @default("{}")
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([provider, eventId])
  @@index([orderId])
  @@index([provider, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  partyId    String?
  party      Party?   @relation(fields: [partyId], references: [id])
  action     String
  entityType String   @default("")
  entityId   String   @default("")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([partyId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model AdminActionRequest {
  id                String    @id @default(cuid())
  requestedByUserId String
  requestedByUser   User      @relation("AdminActionRequestedBy", fields: [requestedByUserId], references: [id])
  targetUserId      String?
  targetUser        User?     @relation("AdminActionTargetUser", fields: [targetUserId], references: [id])
  reviewedByUserId  String?
  reviewedByUser    User?     @relation("AdminActionReviewedBy", fields: [reviewedByUserId], references: [id])
  actionType        String
  status            String    @default("PENDING")
  targetType        String    @default("User")
  targetId          String    @default("")
  previousRole      String    @default("")
  requestedRole     String    @default("")
  reason            String    @default("")
  reviewNote        String    @default("")
  metadata          Json      @default("{}")
  reviewedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([actionType, status])
  @@index([requestedByUserId, createdAt])
  @@index([targetUserId, status])
  @@index([reviewedByUserId, reviewedAt])
}

model AccountRecoveryCase {
  id                        String         @id @default(cuid())
  requestedByUserId         String
  requestedByUser           User           @relation("AccountRecoveryRequestedBy", fields: [requestedByUserId], references: [id])
  targetUserId              String?
  targetUser                User?          @relation("AccountRecoveryTargetUser", fields: [targetUserId], references: [id])
  reviewedByUserId          String?
  reviewedByUser            User?          @relation("AccountRecoveryReviewedBy", fields: [reviewedByUserId], references: [id])
  supportTicketId           String?
  supportTicket             SupportTicket? @relation(fields: [supportTicketId], references: [id])
  email                     String
  requestType               String         @default("ACCOUNT_ACCESS")
  status                    String         @default("OPEN")
  verificationStatus        String         @default("PENDING")
  notes                     String         @default("")
  resolutionNote            String         @default("")
  passwordResetQueuedAt     DateTime?
  emailVerificationQueuedAt DateTime?
  sessionsRevokedAt         DateTime?
  reviewedAt                DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([verificationStatus, createdAt])
  @@index([email, createdAt])
  @@index([targetUserId, status])
  @@index([requestedByUserId, createdAt])
  @@index([reviewedByUserId, reviewedAt])
  @@index([supportTicketId])
}

model SupportTicket {
  id                   String                 @id @default(cuid())
  userId               String?
  user                 User?                  @relation(fields: [userId], references: [id])
  email                String
  subject              String
  message              String
  status               String                 @default("OPEN")
  messages             SupportTicketMessage[]
  accountRecoveryCases AccountRecoveryCase[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model SupportTicketMessage {
  id                String        @id @default(cuid())
  ticketId          String
  ticket            SupportTicket @relation(fields: [ticketId], references: [id])
  authorUserId      String?
  authorUser        User?         @relation(fields: [authorUserId], references: [id])
  messageType       String
  body              String
  outboundMessageId String        @default("")
  createdAt         DateTime      @default(now())

  @@index([ticketId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([messageType, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  scope       String
  key         String
  windowStart DateTime
  count       Int      @default(1)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scope, key, windowStart])
  @@index([expiresAt])
}
