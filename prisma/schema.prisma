generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOST
  PLAYER
  ADMIN
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  role         UserRole      @default(HOST)
  passwordHash String?
  sessions     UserSession[]
  parties      Party[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model UserSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Party {
  id            String       @id @default(cuid())
  title         String
  gameSlug      String
  gameId        String?
  game          Game?        @relation(fields: [gameId], references: [id])
  gameVersionId String?
  gameVersion   GameVersion? @relation(fields: [gameVersionId], references: [id])
  hostId        String
  host          User         @relation(fields: [hostId], references: [id])
  inviteCode    String       @unique
  status        String       @default("PENDING")
  guests        Guest[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Guest {
  id         String   @id @default(cuid())
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id])
  name       String   @default("")
  email      String
  status     String   @default("INVITED")
  guestToken String   @unique
  joinedAt   DateTime?
  createdAt  DateTime @default(now())
}

model Game {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  tagline     String
  description String
  minPlayers  Int
  maxPlayers  Int
  durationMin Int
  durationMax Int
  status      String        @default("DRAFT")
  versions    GameVersion[]
  products    Product[]
  parties     Party[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GameVersion {
  id            String    @id @default(cuid())
  gameId        String
  game          Game      @relation(fields: [gameId], references: [id])
  versionNumber Int
  status        String    @default("DRAFT")
  themes        Json      @default("[]")
  publishedAt   DateTime?
  parties       Party[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([gameId, versionNumber])
}

model Product {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id])
  slug        String   @unique
  name        String
  priceCents  Int
  currency    String   @default("USD")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
